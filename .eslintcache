juliansmith/Projects/rv/client/src/components/Nav.js",["34"],"import React from \"react\";\nimport logo from \"../assets/rvlogo.PNG\";\nimport { Link } from \"react-router-dom\";\nimport \"../styles/Nav.css\";\n\nconst Nav = () => {\n  return (\n    <nav className=\"flex  justify-between bg-gray-900 top-0 nav\">\n      <div className=\"pl-10\">\n        <Link>\n          <img width={75} src={logo} />\n        </Link>\n      </div>\n      <div className=\"flex items-center justify-around space-x-10 pr-10 text-white font-bold\">\n        <Link className=\"hover:text-green-500 hover:bg-gray-800 py-2 px-4 rounded transform transition duration-150 ease-in\">\n          Home\n        </Link>\n        <Link className=\"hover:text-green-500 hover:bg-gray-800 py-2 px-4 rounded transform transition duration-150 ease-in\">\n          About\n        </Link>\n        <Link className=\"hover:text-green-500 hover:bg-gray-800 py-2 px-4 rounded transform transition duration-150 ease-in\">\n          Contact\n        </Link>\n        <Link className=\"hover:text-green-500 hover:bg-gray-800 py-2 px-4 rounded transform transition duration-150 ease-in\">\n          Shop\n        </Link>\n      </div>\n    </nav>\n  );\n};\n\nexport default Nav;\n","/Users/juliansmith/Projects/rv/client/src/components/Contact.js",[],"/Users/juliansmith/Projects/rv/client/src/components/Home.js",[],"/Users/juliansmith/Projects/rv/client/src/components/Banner.js",["35"],"/Users/juliansmith/Projects/rv/client/src/components/Brands.js",[],{"ruleId":"36","replacedBy":"37"},{"ruleId":"38","replacedBy":"39"},{"ruleId":"40","severity":1,"message":"41","line":11,"column":11,"nodeType":"42","endLine":11,"endColumn":40},{"ruleId":"40","severity":1,"message":"41","line":26,"column":13,"nodeType":"42","endLine":26,"endColumn":44},"no-native-reassign",["43"],"no-negated-in-lhs",["44"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOp